{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Auto Tiktok",
  "version": "1.0.0",
  "description": "Công cụ tự động hóa việc sài tiktok",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://tiker.io/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*", "https://tiktok.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
